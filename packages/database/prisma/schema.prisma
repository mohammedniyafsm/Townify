// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  local
  google
  both
}

enum UserRole {
  user
  admin
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String
  password     String? // nullable because Google users have no password
  googleId     String? // stored only for Google OAuth
  authProvider AuthProvider @default(local) // enum
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  profile      String?
  role         UserRole     @default(user) // enum
  avatarId     String?

  avatar       Avatar?      @relation("UserAvatar", fields: [avatarId], references: [id])
  space        Space[]
  spaceMember  SpaceMembers[]
}

model Avatar {
  id         String    @id @default(uuid())
  name       String
  user       User[]    @relation("UserAvatar")
  idle       String
  walkSheet  String
}

model Map{
  id               String        @id @default(uuid())
  name             String
  thumbnail        String
  thumbnailId      String
  configJson       Json

  spaces Space[]
}

model Space {
  id              String      @id @default(uuid())
  name            String
  creatorId       String
  mapId           String
  slug            String      @unique @default(uuid())
  createdAt       DateTime    @default(now())

  creator   User @relation(fields: [creatorId], references: [id])
  map       Map  @relation(fields: [mapId], references: [id])

  members  SpaceMembers[]
  invites  SpaceInvite[]
}

enum MemberStatus {
  active
  blocked
}

model SpaceMembers {
  id            String         @id @default(uuid())
  spaceId       String
  userId        String
  status        MemberStatus   @default(active)
  joinedAt      DateTime       @default(now())

  space   Space @relation(fields: [spaceId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@unique([spaceId, userId])
}

enum InviteType {
  email   
  link    // user requested via shared link
}

enum InviteStatus {
  pending
  approved
  rejected
}

model SpaceInvite {
  id        String       @id @default(uuid())
  spaceId   String
  email     String?      // only for email invite
  userId    String?      // set after login/signup
  type      InviteType
  status    InviteStatus @default(pending)
  createdAt DateTime     @default(now())

  space Space @relation(fields: [spaceId], references: [id])
  @@unique([spaceId, email])
}