// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  local
  google
  both
}

enum UserRole {
  user
  admin
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String
  password     String? // nullable because Google users have no password
  googleId     String? // stored only for Google OAuth
  authProvider AuthProvider @default(local) // enum
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  profile      String?
  role         UserRole     @default(user) // enum
  avatarId     String?
  avatar       Avatar?      @relation("UserAvatar", fields: [avatarId], references: [id])
}

model Avatar {
  id    String @id @default(uuid())
  name  String
  user  User[] @relation("UserAvatar")
  walkSheet String
}
